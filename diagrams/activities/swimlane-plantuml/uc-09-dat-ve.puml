@startuml
title UC-09 Activity Swimlane - Đặt vé tàu

|Hành khách|
start
:Chọn chuyến, chặng và ghế;
:Nhập thông tin hành khách;
:Xác nhận đặt vé;

|Hệ thống|
if (Ghế còn trống trên toàn bộ đoạn đi?) then (Không)
  :Báo lỗi ghế đã được giữ hoặc đặt;
  |Hành khách|
  :Chọn ghế khác;
  stop
else (Có)
  :Tạo Booking PENDING;
endif

|Cổng thanh toán / Email|
:Thanh toán VNPay hoặc ví;

|Hệ thống|
if (Thanh toán thành công?) then (Không)
  :Đánh dấu PAYMENT_FAILED;
  :Giải phóng giữ chỗ;
  stop
else (Có)
  :Tạo Ticket;
  :Tạo TicketSeatSegment;
endif

if (DB unique chặn trùng đoạn ghế?) then (Có)
  :Hoàn tiền nếu phát sinh race condition;
else (Không)
  |Cổng thanh toán / Email|
  :Gửi vé điện tử qua email;
endif

|Hành khách|
stop
@enduml
