@startuml
title UC-08 Activity Swimlane - Quản lý ví điện tử

|Hành khách|
start
switch (Chọn nghiệp vụ ví?)
case (Nạp tiền)
  :Nhập số tiền nạp;
  |Hệ thống|
  :Tạo Transaction PENDING;
  :Tạo URL thanh toán;
  |VNPay / Admin|
  :Xử lý thanh toán VNPay;
  |Hệ thống|
  if (Thanh toán thành công?) then (Có)
    :Cộng số dư và đánh dấu COMPLETED;
  else (Không)
    :Báo lỗi giao dịch;
  endif
case (Rút tiền)
  |Hành khách|
  :Nhập ngân hàng, số tiền, mã PIN;
  |Hệ thống|
  if (PIN và số dư hợp lệ?) then (Có)
    :Trừ số dư tạm;
    :Tạo yêu cầu rút PENDING;
    |VNPay / Admin|
    :Admin xử lý yêu cầu rút tiền;
  else (Không)
    :Báo lỗi giao dịch;
  endif
case (Lịch sử)
  |Hành khách|
  :Xem số dư và lịch sử giao dịch;
  |Hệ thống|
  :Trả danh sách Transaction;
endswitch

|Hành khách|
stop
@enduml
