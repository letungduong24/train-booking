// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// User

model User {
  id            String         @id @default(uuid())
  profilePic    String?
  email         String         @unique
  phone         String?        @unique
  password      String? // nullable để hỗ trợ Google OAuth (users không có mật khẩu)
  name          String?
  googleId      String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens      RefreshToken[]
  bookings           Booking[]
  driverTrips        Trip[]            @relation("DriverTrips")
  reportedSeatIssues SeatIssueReport[] @relation("ReportedIssues")
  // Role & Permissions
  role          UserRole       @default(USER)

  // Verification & Security
  isEmailVerified          Boolean   @default(false)
  verificationToken        String?   @unique
  verificationTokenExpires DateTime?

  passwordResetToken        String?   @unique
  passwordResetTokenExpires DateTime?

  walletPinResetToken        String?   @unique
  walletPinResetTokenExpires DateTime?

  // Wallet info
  balance      Float         @default(0)
  walletPin    String?
  transactions Transaction[]

  // Admin Controls
  isBanned Boolean @default(false)
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// Wallet & Transactions

model Transaction {
  id            String            @id @default(uuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  amount        Float // Số tiền (+ hoặc -)
  type          TransactionType // DEPOSIT, WITHDRAW, PAYMENT, REFUND
  paymentMethod String? // WALLET, VNPAY, MOMO, etc. (for PAYMENT type)
  status        TransactionStatus @default(PENDING)

  referenceId String? // Booking ID, Payment Gateway Ref, e.g.
  description String?

  // Withdrawal Info (Only for type=WITHDRAW)
  bankName    String?
  bankAccount String?
  accountName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  PAYMENT
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum UserRole {
  USER
  ADMIN
  DRIVER
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TrainStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum CoachStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum RouteStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

// Network Versioning
model Network {
  id        String        @id @default(uuid())
  version   Int           @unique
  name      String        // VD: "Bản đồ mạng lưới đường sắt T5/2026"
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  stations  Station[]
  lines     RailwayLine[]
  routes    Route[]
}

// Station
// Station

model Station {
  id        String         @id @default(uuid())
  code      String
  name      String
  latitude  Float
  longitude Float
  networkId String
  network   Network        @relation(fields: [networkId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  routes    RouteStation[]

  @@unique([code, networkId])
}

model Route {
  id                String         @id @default(uuid())
  code              String
  version           Int            @default(1)
  networkId         String
  network           Network        @relation(fields: [networkId], references: [id])
  name              String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  stations          RouteStation[]
  trips             Trip[]
  status            RouteStatus    @default(DRAFT)
  durationMinutes   Int            @default(0) // Thời gian chạy (phút)
  turnaroundMinutes Int            @default(60) // Thời gian nghỉ quay đầu (phút)
  totalDistanceKm   Float          @default(0) // Tổng chiều dài tuyến đường (do Turf.js tự đo)

  // Pricing configuration
  basePricePerKm Float @default(1000) // Giá cơ bản mỗi km (VND)
  stationFee     Float @default(0) // Phí ra vào bến (VND)

  // Geographic visual path
  pathCoordinates Json? // Stores GeoJSON MultiLineString coordinates snapped from RailwayLine

  @@unique([code, version])
}

// Physical infrastructure: the railway lines connecting stations
model RailwayLine {
  id              String   @id @default(uuid())
  name            String
  pathCoordinates Json // Stores GeoJSON MultiLineString coordinates
  networkId       String
  network         Network  @relation(fields: [networkId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RouteStation {
  routeId           String
  stationId         String
  index             Int
  distanceFromStart Float
  durationFromStart Int      @default(0) // Duration in minutes from the first station to this station
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  route             Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  station           Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@id([routeId, stationId])
}

// Train
model CoachTemplate {
  id          String      @id @default(uuid())
  code        String      @unique
  name        String
  description String?
  layout      CoachLayout
  totalRows   Int
  totalCols   Int
  tiers       Int         @default(1)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  coaches     Coach[]

  // Pricing configuration
  coachMultiplier Float @default(1.0) // Hệ số nhân giá theo loại toa
  tierMultipliers Json  @default("{\"0\": 1.0}") // Hệ số nhân theo tầng: {"0": 1.0, "1": 1.2, "2": 1.1, "3": 0.8}
}

enum CoachLayout {
  SEAT
  BED
}

model Train {
  id              String      @id @default(uuid())
  code            String      @unique
  name            String
  status          TrainStatus @default(ACTIVE)
  averageSpeedKmH Int         @default(60) // Vận tốc trung bình (km/h) để gợi ý thời gian chạy
  coaches         Coach[]
  trips           Trip[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Coach {
  id         String        @id @default(uuid())
  name       String
  order      Int
  status     CoachStatus   @default(ACTIVE)
  trainId    String
  train      Train         @relation(fields: [trainId], references: [id], onDelete: Cascade)
  templateId String
  template   CoachTemplate @relation(fields: [templateId], references: [id])

  seats Seat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainId])
}

model Seat {
  id        String     @id @default(uuid())
  name      String
  rowIndex  Int
  colIndex  Int
  status    SeatStatus @default(AVAILABLE)
  type      SeatType   @default(STANDARD)
  tier      Int        @default(0) // Tầng ghế cho tính giá (0-3)
  coachId            String
  coach              Coach             @relation(fields: [coachId], references: [id], onDelete: Cascade)
  tickets            Ticket[]
  seatIssueReports   SeatIssueReport[]
  proposedSeatIssues SeatIssueReport[] @relation("ProposedSeat")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([coachId, rowIndex, colIndex, tier])
}

enum SeatStatus {
  AVAILABLE
  DISABLED
  MAINTENANCE
}

enum SeatType {
  VIP
  STANDARD
  ECONOMY
  OTHER
}

// Trip Management

model Trip {
  id            String     @id @default(uuid())
  routeId       String
  route         Route      @relation(fields: [routeId], references: [id], onDelete: Cascade)
  trainId       String
  train         Train      @relation(fields: [trainId], references: [id], onDelete: Cascade)
  departureTime DateTime // Thời gian khởi hành (bao gồm cả ngày và giờ)
  endTime       DateTime // Thời gian kết thúc (bao gồm cả thời gian chạy + nghỉ)
  status        TripStatus @default(SCHEDULED) // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED

  // Delay management (phút) - Giữ nguyên departureTime/endTime gốc
  departureDelayMinutes Int               @default(0) // Delay khởi hành
  arrivalDelayMinutes   Int               @default(0) // Delay kết thúc
  tickets               Ticket[]
  bookings              Booking[]
  driverId              String?
  driver                User?             @relation("DriverTrips", fields: [driverId], references: [id])
  seatIssues            SeatIssueReport[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([routeId])
  @@index([trainId])
  @@index([departureTime])
}

// Booking Management

// Booking = Đơn hàng (Giỏ hàng tổng)
enum BookingStatus {
  PENDING
  PAID
  CANCELLED
  PAYMENT_FAILED
}

model Booking {
  id           String        @id @default(uuid())
  code         String        @unique // Mã đặt chỗ (RAILFLOW-YYYYMMDD-XXXX)
  tripId       String
  trip         Trip          @relation(fields: [tripId], references: [id])
  userId       String? 
  user         User?         @relation(fields: [userId], references: [id])
  contactName  String?
  contactPhone String?
  contactEmail String?
  status       BookingStatus @default(PENDING) // Thay vì String
  totalPrice   Float
  metadata     Json? 
  tickets      Ticket[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tripId])
  @@index([userId])
  @@index([code])
}

// PassengerGroup = Phân loại hành khách (Người lớn, Sinh viên, Người cao tuổi, Trẻ em)
model PassengerGroup {
  id           String   @id @default(uuid())
  code         String   @unique // ADULT, STUDENT, ELDERLY, CHILD
  name         String // "Người lớn", "Sinh viên", "Người cao tuổi", "Trẻ em"
  discountRate Float    @default(0) // 0.1 = giảm 10%, 0.15 = giảm 15%
  description  String?
  minAge       Int? // Tuổi tối thiểu (VD: ELDERLY >= 60)
  maxAge       Int? // Tuổi tối đa (VD: CHILD < 12)
  tickets      Ticket[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Ticket = Vé lẻ (Mỗi vé gắn với 1 hành khách trên 1 ghế của 1 chuyến tàu)
model Ticket {
  id               String         @id @default(uuid())
  bookingId        String
  booking          Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tripId           String // Vì trong 1 đơn hàng, vé 1 có thể đi tàu SE1, vé 2 có thể đi tàu SE3
  trip             Trip           @relation(fields: [tripId], references: [id])
  seatId           String
  seat             Seat           @relation(fields: [seatId], references: [id])
  passengerName    String // Tên hành khách
  passengerId      String // CCCD/CMND (hoặc "N/A" cho trẻ em)
  passengerGroupId String // Phân loại hành khách
  passengerGroup   PassengerGroup @relation(fields: [passengerGroupId], references: [id])
  fromStationIndex Int // Chỉ số ga đi trong route
  toStationIndex   Int // Chỉ số ga đến trong route
  price            Float // Giá của riêng vé này (đã áp dụng giảm giá)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([bookingId])
  @@index([tripId])
  @@index([seatId])
  @@index([passengerGroupId])
  @@unique([bookingId, seatId])
}

enum SeatIssueStatus {
  PENDING
  WAITING_CUSTOMER_CONFIRMATION
  RESOLVED
  REJECTED
}

model SeatIssueReport {
  id             String          @id @default(uuid())
  tripId         String
  trip           Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  seatId         String
  seat           Seat            @relation(fields: [seatId], references: [id], onDelete: Cascade)
  issueType      String          // "Ghế gãy/hỏng", "Ghế bẩn", "Không điều chỉnh được", "Thiết bị hỏng (đèn, ổ cắm)", "Khác"
  description    String
  reportedById   String
  reportedBy     User            @relation("ReportedIssues", fields: [reportedById], references: [id])
  status         SeatIssueStatus @default(PENDING)
  rejectReason   String?
  
  // Tự động đề xuất đổi ghế
  token          String?         @unique
  tokenExpires   DateTime?
  proposedSeatId String?
  proposedSeat   Seat?           @relation("ProposedSeat", fields: [proposedSeatId], references: [id])
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([tripId])
  @@index([seatId])
  @@index([tripId, seatId, status])
  @@index([reportedById])
}
